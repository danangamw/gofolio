# App
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=change-me-to-a-random-32-char-secret-key

# Database
DATABASE_URL=postgres://user:password@localhost:5432/go_cms?sslmode=disable
# Connection pool — tune based on your server resources and expected load
# DB_MAX_IDLE_CONNS: max connections kept idle in the pool (default: 10)
# DB_MAX_OPEN_CONNS: max total open connections to the DB (default: 100)
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100

# Redis (optional, fallback to PostgreSQL sessions if not set)
REDIS_URL=redis://localhost:6379

# Storage
UPLOAD_STORAGE=local
UPLOAD_DIR=./uploads
S3_BUCKET=go-cms
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=https://minio.yoursite.com
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Admin seed (only used during seeding, plaintext hashed immediately)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-secure-password

# ─── Telemetry / Observability ────────────────────────────────────────────────
# Nama layanan yang tampil di Grafana (Tempo, Loki, Prometheus)
SERVICE_NAME=go-cms
# Versi layanan — idealnya di-inject dari git tag saat build
SERVICE_VERSION=dev
# Alamat Grafana Alloy (OTLP gRPC collector)
# Saat development lokal: localhost:4317
# Saat Docker Compose   : alloy:4317
OTLP_ENDPOINT=localhost:4317
# Log level: debug | info | warn | error
LOG_LEVEL=info
# Password Grafana dashboard (default: admin)
GRAFANA_PASSWORD=4Dm1nd4nan6
