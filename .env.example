# App
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=change-me-to-a-random-32-char-secret-key

# Database
DATABASE_URL=postgres://user:password@localhost:5432/go_cms?sslmode=disable

# Redis (optional, fallback to PostgreSQL sessions if not set)
REDIS_URL=redis://localhost:6379

# Storage
UPLOAD_STORAGE=local
UPLOAD_DIR=./uploads
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Admin seed (only used during seeding, plaintext hashed immediately)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-secure-password
